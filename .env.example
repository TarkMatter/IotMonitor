# =============================================
# IotMonitor 環境変数テンプレート
# このファイルをコピーして .env を作成すること
# .env は Git にコミットしないこと
# =============================================

# --- MQTT ---
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=iot/environment
DEVICE_ID=raspi-01
DEVICE_READ_INTERVAL_SEC=10

# --- InfluxDB ---
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=IotMonitor
INFLUXDB_BUCKET=environment

# --- 通知チャネル ---
# line | slack | both
NOTIFY_CHANNEL=line

# --- LINE Notify ---
LINE_NOTIFY_TOKEN=your-line-notify-token

# --- Slack ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# --- アラート閾値 ---
ALERT_TEMP_HIGH=35.0
ALERT_TEMP_LOW=5.0
ALERT_HUMIDITY_HIGH=80.0
ALERT_HUMIDITY_LOW=20.0
ALERT_CO2_HIGH=1500
ALERT_COOLDOWN_MINUTES=15
