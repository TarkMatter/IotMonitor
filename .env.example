# =============================================
# IotMonitor 環境変数テンプレート
# このファイルをコピーして .env を作成すること
# .env は Git にコミットしないこと
# =============================================

# --- MQTT ---
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=iot/environment
DEVICE_ID=raspi-01
DEVICE_READ_INTERVAL_SEC=10

# --- InfluxDB ---
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=IotMonitor
INFLUXDB_BUCKET=environment

# --- 通知チャネル ---
# line | slack | both
NOTIFY_CHANNEL=line

# --- LINE Messaging API ---
# LINE Developers → チャンネル → Messaging API 設定 → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
# LINE Developers → チャンネル → 基本設定 → Your user ID（U から始まる文字列）
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Slack ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# --- デバイス設定 ---
# 複数デバイスをシミュレートする場合はカンマ区切りで指定（省略時は DEVICE_ID のみ）
# DEVICE_IDS=raspi-01,raspi-02

# --- センサーハードウェア ---
# SDS011 PM2.5 センサーの UART ポート（Raspberry Pi の USB シリアルアダプタ）
SDS011_UART_PORT=/dev/ttyUSB0

# --- アラート閾値 ---
ALERT_TEMP_HIGH=35.0
ALERT_TEMP_LOW=5.0
ALERT_HUMIDITY_HIGH=80.0
ALERT_HUMIDITY_LOW=20.0
ALERT_CO2_HIGH=1500
# PM2.5 環境省基準値（24 時間平均 35μg/m³）
ALERT_PM25_HIGH=35.0
ALERT_COOLDOWN_MINUTES=15
